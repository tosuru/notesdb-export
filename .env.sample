# ====================================================================
# 環境変数 設定サンプル (.env.sample)
# 
# 利用法:
# 1. このファイルをコピーし、ファイル名を `.env` に変更します。
# 2. 環境に合わせて各変数の値を書き換えてください。
# ====================================================================

# Notesパスワード (省略可能・セキュリティ確保のため環境変数での設定を推奨)
NOTES_PASSWORD="your_notes_password"

# NotesリンクのリダイレクトベースURL
NOTES_REDIRECT_BASE="http://iszhqw01.isuzu.co.jp/Tools/Redirect.nsf/Index?OpenPage&NotesURL="

# Notesサーバー名のドメインサフィックス（FQDN化用）
NOTES_DOMAIN_SUFFIX="isuzu.co.jp"

# Box検索のベースURL
BOX_SEARCH_BASE="https://isuzu.app.box.com/folder/0/search?query="

# プログラム実行パス（原則 src で固定）
PYTHONPATH="src"
